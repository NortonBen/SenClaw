{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SemaClaw",
  "version": "0.1.1",
  "identifier": "com.semaclaw.app",
  "build": {
    "frontendDist": "../web/dist"
  },
  "app": {
    "windows": [
      {
        "label": "chat",
        "title": "SemaClaw Chat",
        "url": "http://127.0.0.1:18788/?embed=1&app=1",
        "width": 420,
        "height": 640,
        "minWidth": 360,
        "minHeight": 480,
        "visible": false,
        "skipTaskbar": true,
        "resizable": true
      },
      {
        "label": "main",
        "title": "SemaClaw",
        "url": "http://127.0.0.1:18788/?app=1",
        "width": 1280,
        "height": 820,
        "minWidth": 880,
        "minHeight": 560,
        "visible": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app", "nsis", "msi", "deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../web/dist": "web/dist",
      "binaries": "binaries"
    }
  }
}
