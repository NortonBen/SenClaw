{
  "id": "ssh-manager",
  "name": "SSH Manager",
  "description": "Standalone SSH Manager App Space for SenClaw. Provides web terminal and secure command execution.",
  "icon": "S",
  "runtime": {
    "kind": "server",
    "start": "./ssh-manager",
    "healthPath": "/"
  },
  "integration": {
    "type": "iframe",
    "url": "/"
  },
  "bridge": {
    "postMessage": true,
    "capabilities": ["space.rest"]
  },
  "mcp": {
    "name": "ssh-manager-mcp",
    "transport": "http",
    "path": "/api/mcp/sse",
    "description": "SSH Manager MCP for managing connections and running commands",
    "autoRegister": true
  },
  "skills": [
    {
      "name": "ssh-reporting",
      "path": "skills/ssh-reporting",
      "triggers": ["báo cáo ssh", "ssh report", "thống kê server"]
    },
    {
      "name": "ssh-guide",
      "path": "skills/ssh-guide",
      "triggers": ["hướng dẫn ssh", "ssh guide", "cách dùng ssh"]
    },
    {
      "name": "ssh-connect",
      "path": "skills/ssh-connect",
      "triggers": ["kết nối ssh", "connect ssh", "thực hiện lệnh", "vào server"]
    }
  ]
}
