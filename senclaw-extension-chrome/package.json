{
  "name": "SenClaw Extension",
  "description": "Chrome extension for remote browser control by SemaClaw agents",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
